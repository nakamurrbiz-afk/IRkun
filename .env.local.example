# ============================================================
# IR Alert — 環境変数テンプレート
# このファイルをコピーして .env.local を作成し、各値を設定してください。
# .env.local は .gitignore に含まれているため git に commit されません。
# ============================================================

# EDINET DB API キー
# 取得: https://edinetdb.jp/developers/dashboard
EDINET_API_KEY=your_edinet_api_key_here

# Claude API キー（Claude Pro とは別の課金）
# 取得: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Discord Webhook URL
# 取得: Discordサーバー設定 → 連携サービス → ウェブフック → 新しいウェブフック
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxxx/xxxxxxxxx

# ウォッチリスト（証券コード、カンマ区切り）
# 例: トヨタ(7203), SoftBank(9984), Sony(6758)
WATCHLIST_CODES=7203,9984,6758

# Cron 認証シークレット（任意の文字列。GitHub Actions Secrets と合わせる）
# 生成例: openssl rand -hex 32
CRON_SECRET=your_random_secret_here
